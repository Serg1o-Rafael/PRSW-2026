<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="css/estilo.css">
    <title>Document</title>
</head>
<body>
    <header>
        <nav id="menu">
            <a href="/">Home</a> | <a href="/validaCPF">Verifica CPF</a> | <a href="/confirmou">Confirma Senha</a>
        </nav>
    </header>
    <section>
        <h1 id="titulo">Cadastro de Clientes</h1>
    </section>
    
    <section id="caixa_formulario">
        <form action="/add_cliente" method="post">

            <label for="nome">Nome</label>
            <input type="text" name="nome" id="nome" size="30" maxlength="70">

               <label for="nome">CPF</label>
            <input type="text" name="cpf" id="cpf" size="11" maxlength="11">

               <label for="senha">Senha</label>
            <input type="password" name="senha" id="senha" size="8" maxlength="8">

               <label for="confirmasenha">Confirma senha</label>
            <input type="password" name="confirmasenha" id="confirmasenha" size="8" maxlength="8">

            <button type="submit">Cadastrar</button>
        </form>
    </section>

</body>
</html>